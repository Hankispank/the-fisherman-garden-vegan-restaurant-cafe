ADMIN_PASSWORD=change-me
SESSION_SECRET=generate-with-openssl-rand-hex-32

# Orders/reservations: public POST /.netlify/functions/submit-order → Netlify Blobs store "orders".
# Admin panel: GET /.netlify/functions/get-orders, POST /.netlify/functions/update-order (session auth).
# Booking notifications (optional): set SMTP_* in Netlify env for owner + customer emails on reservation.
SMTP_USER=thefisherman.veganrestaurant@gmail.com
SMTP_PASS=your-gmail-app-password
